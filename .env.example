# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=rag_platform

DATABASE_URL=postgresql://postgres:your_password@db:5432/rag_platform

APP_ENV=development

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333

# JWT
JWT_SECRET_KEY=your_secret_key
JWT_ALGORITHM=HS256

# ============================================================
# OPTION 1: Ollama (local, free, no API key needed)
# ============================================================
# Install: https://ollama.ai
# Pull models: ollama pull llama3.2:3b && ollama pull nomic-embed-text

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=llama3.2:3b

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Placeholder (required by config but unused with Ollama)
OPENAI_API_KEY=sk-placeholder

# ============================================================
# OPTION 2: Groq (fast, free tier, needs API key)
# ============================================================
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant

# ============================================================
# OPTION 3: OpenAI (paid, highest quality)
# ============================================================
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-3.5-turbo
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
